[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	ignorecase = true
[remote "origin"]
	url = https://github.com/VanemKrAu/Mineradio-Tauri.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[remote "upstream"]
	url = https://github.com/zzstar101/Mineradio-Tauri.git
	fetch = +refs/heads/*:refs/remotes/upstream/*
	gh-resolved = base
